local player = {}
local platforms = {
	{ width = 0, height = 20, x = 0, y = 780 },
	{ width = 0, height = 20, x = 0, y = 630 },
}

local mode = "menu"

function love.load()
	love.window.setTitle("Juggle Kong")
	love.window.setMode(800, 800)

	love.graphics.setDefaultFilter("nearest", "nearest")

	for i, platform in ipairs(platforms) do
		platform.width = love.graphics.getWidth()
	end

	love.graphics.setBackgroundColor(1, 1, 1)
	resetPlayer()
	player.ground = player.y
	player.ground = platforms[1].y - player.height

	print("Game loaded! Press ESC to quit")
end

function resetPlayer()
	player = {
		x = 400,
		y = 740,
		width = 20,
		height = 40,
		speed = 200,
		jump_height = -200,
		y_velocity = 0,
		gravity = -500,
		alive = true,
	}
end

function love.update(dt)
	if player.alive then
		-- make sure the player doesn't go off the right side
		if player.x < (love.graphics.getWidth() - player.width) then
			if love.keyboard.isDown("d") or love.keyboard.isDown("right") then
				player.x = player.x + player.speed * dt
			end
		end

		-- make sure the player doesn't go off the left side
		if player.x > 0 then
			if love.keyboard.isDown("a") or love.keyboard.isDown("left") then
				player.x = player.x - player.speed * dt
			end
		end

		if love.keyboard.isDown("space") then
			if player.y_velocity == 0 then
				player.y_velocity = player.jump_height
			end
		end

		if player.y_velocity ~= 0 then
			player.y = player.y + player.y_velocity * dt
			player.y_velocity = player.y_velocity - player.gravity * dt
		end

		if player.y > player.ground then
			player.y_velocity = 0
			player.y = player.ground
		end
	end
end

function love.draw()
	-- rendering platforms

	for i, platform in ipairs(platforms) do
		love.graphics.setColor(1, 1, 0)
		love.graphics.rectangle("fill", platform.x, platform.y, platform.width, platform.height)
	end

	-- rendering player
	love.graphics.setColor(0, 1, 0)
	love.graphics.rectangle("fill", player.x, player.y, player.width, player.height)
end

function love.keypressed(key)
	if key == "escape" then
		love.event.quit()
	end
end
